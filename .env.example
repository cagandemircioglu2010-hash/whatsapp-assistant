# Application database: users, permissions, messages and audit events.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/company_assistant
DATABASE_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/company_assistant
DATABASE_SSL=false

# Restricted role created by `npm run db:provision-readonly`.
# For a separate existing company DB, point this admin URL at that database.
COMPANY_DATABASE_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/company_assistant
COMPANY_READONLY_USER=company_assistant_reader
COMPANY_READONLY_PASSWORD=replace-with-a-long-random-password
COMPANY_READONLY_DATABASE_URL=postgresql://company_assistant_reader:replace-with-a-long-random-password@localhost:5432/company_assistant

# At least 32 random characters. Used to HMAC-hash phone identifiers in message history.
PHONE_HASH_SECRET=replace-with-at-least-32-random-characters
DEFAULT_PHONE_COUNTRY=TR
COMPANY_TIMEZONE=Europe/Istanbul

HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Keep false until the Meta test number and webhook are configured.
WHATSAPP_ENABLED=false
WHATSAPP_VERIFY_TOKEN=replace-with-a-random-verification-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v25.0
META_APP_SECRET=
REQUIRE_WHATSAPP_SIGNATURE=true

# Day 6: enable after adding an OpenAI project API key.
LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_REASONING_EFFORT=low
LLM_MAX_TOOL_CALLS=4
LLM_MAX_OUTPUT_TOKENS=700
LLM_TIMEOUT_MS=25000

# Optional: identity used only when running the standalone stdio MCP server.
# The WhatsApp application binds identity from its verified whitelist instead.
MCP_ACTOR_PHONE=
