# Local Docker database password. Generate a unique value; never reuse it in production.
POSTGRES_PASSWORD=replace-with-a-long-random-local-password

# Application database: migrations use the admin URL; the running service uses the restricted role.
DATABASE_ADMIN_URL=postgresql://postgres:replace-with-the-local-password@localhost:5432/company_assistant
APP_RUNTIME_USER=company_assistant_app
APP_RUNTIME_PASSWORD=replace-with-a-different-long-random-password
DATABASE_URL=postgresql://company_assistant_app:replace-with-the-app-runtime-password@localhost:5432/company_assistant
DATABASE_SSL_MODE=disable
# Production: verify-full. For a private CA, set DATABASE_CA_CERT_FILE to a mounted secret file.
DATABASE_CA_CERT_FILE=

# Restricted role created by `npm run db:provision-readonly`.
# For a separate existing company DB, point this admin URL at that database.
COMPANY_DATABASE_ADMIN_URL=postgresql://postgres:replace-with-the-local-password@localhost:5432/company_assistant
COMPANY_READONLY_USER=company_assistant_reader
COMPANY_READONLY_PASSWORD=replace-with-a-long-random-password
COMPANY_READONLY_DATABASE_URL=postgresql://company_assistant_reader:replace-with-a-long-random-password@localhost:5432/company_assistant
# Keep the three built-in sales/project/task reporting views enabled. Set false
# only when onboarding another PostgreSQL database exclusively through the
# schema-aware LLM tools.
COMPANY_REPORTS_ENABLED=true
COMPANY_DATABASE_SSL_MODE=disable
COMPANY_DATABASE_CA_CERT_FILE=

# Versioned identifier HMAC ring. Generate every value with `openssl rand -base64 32`.
# During migration, include the old PHONE_HASH_SECRET under key id "legacy" until old message rows expire.
IDENTIFIER_HASH_ACTIVE_KEY_ID=local_2026
IDENTIFIER_HASH_KEYS={"local_2026":"replace-with-openssl-rand-base64-32"}
IDENTIFIER_HASH_KEYS_FILE=

# Separate key ring for tamper-evident audit chaining.
AUDIT_INTEGRITY_ACTIVE_KEY_ID=local_2026
AUDIT_INTEGRITY_KEYS={"local_2026":"replace-with-a-different-openssl-rand-base64-32"}
AUDIT_INTEGRITY_KEYS_FILE=

# Separate HMAC secret used only for OpenAI safety identifiers.
SAFETY_IDENTIFIER_SECRET=replace-with-at-least-32-random-characters

# AES-256-GCM key ring. Generate each value with `openssl rand -base64 32`.
# Keep old keys in the JSON object while rotating; only the active key encrypts new values.
DATA_ENCRYPTION_ACTIVE_KEY_ID=
DATA_ENCRYPTION_KEYS=
DATA_ENCRYPTION_KEYS_FILE=

MESSAGE_RETENTION_DAYS=30
MESSAGE_RECORD_RETENTION_DAYS=90
AUDIT_RETENTION_DAYS=365
WEBHOOK_BODY_LIMIT_BYTES=262144
USER_RATE_LIMIT_PER_MINUTE=20
INGRESS_SENDER_RATE_LIMIT_PER_MINUTE=60
INGRESS_GLOBAL_RATE_LIMIT_PER_MINUTE=600
DATA_LIFECYCLE_INTERVAL_MINUTES=60
MESSAGE_WORKER_CONCURRENCY=4
# Unauthorized messages per sender per minute past which the sender is locked
# out (silently ignored) for the rest of the window.
ABUSE_LOCKOUT_THRESHOLD_PER_MINUTE=10
# Reject inbound webhook messages whose Meta timestamp is older/newer than this
# many seconds (replay hardening). 0 disables the check.
WEBHOOK_MESSAGE_MAX_AGE_SECONDS=0
DEFAULT_PHONE_COUNTRY=TR
COMPANY_TIMEZONE=Europe/Istanbul
# Language for system notices the bot sends on its own (tr or en).
ASSISTANT_LOCALE=tr
OPS_TOKEN=replace-with-a-random-secret-at-least-32-characters

# Optional signed outbound event notifications (lockouts, permanent send
# failures). Leave both blank to disable. The receiver verifies the
# x-assistant-signature HMAC over the request body with this secret.
INTEGRATION_WEBHOOK_URL=
INTEGRATION_WEBHOOK_SECRET=
INTEGRATION_WEBHOOK_TIMEOUT_MS=4000

HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Keep false until the Meta test number and webhook are configured.
WHATSAPP_ENABLED=false
WHATSAPP_VERIFY_TOKEN=replace-with-a-random-verification-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v25.0
META_APP_SECRET=
REQUIRE_WHATSAPP_SIGNATURE=true
# Logs only event counts, message types, statuses, and phone-number ID match results.
WHATSAPP_DEBUG_LOGGING=false

# Gemini 3.5 Flash has a limited free tier. Free-tier prompts may be used by Google to improve products.
LLM_ENABLED=false
# When true, non-company questions are answered by the LLM while company facts
# remain restricted to the permission-checked reporting tools.
LLM_GENERAL_CHAT_ENABLED=false
# Opt-in, admin/executive-only schema discovery and structured read-only query
# mode. The database role must have SELECT only on reviewed reporting views.
LLM_SCHEMA_DISCOVERY_ENABLED=false
LLM_SCHEMA_ALLOWED_SCHEMAS=assistant_reporting
# JSON array of explicitly reviewed views, columns, and a separate data ACL.
# Omit this variable to use the three built-in assistant_reporting policies.
# LLM_SCHEMA_RELATION_MANIFEST=[{"relation":"analytics.metrics","columns":["metric_name","metric_value"],"filterColumns":["metric_name"],"resource":"company.database.relation.metrics","allowUnfiltered":false}]
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_REASONING_EFFORT=low
LLM_MAX_TOOL_CALLS=4
LLM_MAX_OUTPUT_TOKENS=700
LLM_TIMEOUT_MS=25000

# Optional: identity used only when running the standalone stdio MCP server.
# The WhatsApp application binds identity from its verified whitelist instead.
MCP_ACTOR_PHONE=
