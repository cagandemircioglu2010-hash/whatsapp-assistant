{
  "name": "company-whatsapp-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Secure WhatsApp assistant backend with a read-only company reporting layer.",
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:stress": "vitest run tests/stress.test.ts",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test:coverage && npm run build",
    "security:scan": "node scripts/scan-secrets.mjs",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "node dist/src/db/migrate.js",
    "db:migrate:app": "MIGRATION_SCOPE=app tsx src/db/migrate.ts",
    "db:migrate:security-prepare": "MIGRATION_SCOPE=app MIGRATION_THROUGH=005_security_operations.sql tsx src/db/migrate.ts",
    "db:migrate:company": "MIGRATION_SCOPE=company tsx src/db/migrate.ts",
    "db:provision-readonly": "tsx scripts/provision-readonly-role.ts",
    "db:provision-app-role": "tsx scripts/provision-app-role.ts",
    "db:encrypt-existing": "tsx scripts/encrypt-existing-data.ts",
    "db:backfill-security": "tsx scripts/encrypt-existing-data.ts",
    "db:backfill-security:prod": "node dist/scripts/encrypt-existing-data.js",
    "db:purge-expired": "tsx scripts/purge-expired-data.ts",
    "db:purge-expired:prod": "node dist/scripts/purge-expired-data.js",
    "db:erase-client-data": "tsx scripts/erase-client-data.ts",
    "db:erase-client-data:prod": "node dist/scripts/erase-client-data.js",
    "db:erase-company-source": "tsx scripts/erase-company-source-data.ts",
    "db:erase-company-source:prod": "node dist/scripts/erase-company-source-data.js",
    "db:erase-user-data": "tsx scripts/erase-user-data.ts",
    "db:erase-user-data:prod": "node dist/scripts/erase-user-data.js",
    "db:verify-audit": "tsx scripts/verify-audit-log.ts",
    "db:verify-audit:prod": "node dist/scripts/verify-audit-log.js",
    "db:add-user": "tsx scripts/add-whitelisted-user.ts",
    "db:set-user-active": "tsx scripts/set-user-active.ts",
    "db:set-legal-hold": "tsx scripts/set-legal-hold.ts",
    "db:set-legal-hold:prod": "node dist/scripts/set-legal-hold.js",
    "db:seed-demo": "tsx scripts/seed-demo-company-data.ts",
    "reports:smoke": "tsx scripts/smoke-test-reports.ts",
    "whatsapp:diagnose": "tsx scripts/diagnose-whatsapp.ts",
    "mock:meta": "tsx scripts/mock-meta-server.ts",
    "e2e:local": "tsx scripts/e2e-local.ts",
    "ops:readiness": "tsx scripts/verify-production-readiness.ts",
    "ops:readiness:prod": "node dist/scripts/verify-production-readiness.js",
    "mcp:stdio": "tsx src/mcp/stdio-server.ts",
    "mcp:stdio:prod": "node dist/src/mcp/stdio-server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.4.0",
    "libphonenumber-js": "^1.12.10",
    "openai": "^6.47.0",
    "pg": "^8.16.3",
    "pg-format": "^1.0.4",
    "pino": "^9.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.4",
    "@types/pg-format": "^1.0.5",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
